      "parameters": {
        "jsCode": "const body = $input.first().json.body;\nconst headers = $input.first().json.headers;\n\n// API Key validation\nconst validApiKey = \"black-elephant-2026\";\nconst incomingKey = headers?.[\"x-api-key\"];\n\nif (!incomingKey || incomingKey !== validApiKey) {\n  throw new Error(\"401: Unauthorized - Invalid or missing API key\");\n}\n\n// Input validation\nif (!body.message || body.message.trim() === \"\") {\n  throw new Error(\"400: Bad Request - message field is required\");\n}\n\nif (body.message.length > 1000) {\n  throw new Error(\"400: Bad Request - message exceeds 1000 characters\");\n}\n\nif (!body.session_id) {\n  throw new Error(\"400: Bad Request - session_id is required\");\n}\n\nreturn {\n  sessionId: body.session_id,\n  session_id: body.session_id,\n  user_id: body.user_id || \"anonymous\",\n  chatInput: body.message.trim(),\n  request_time: new Date().toISOString()\n};"
