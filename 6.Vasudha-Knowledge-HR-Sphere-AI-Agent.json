    {
      "parameters": {
        "jsCode": "const results = $input.first().json;\nconst matchList = results.matches || [];\n\nlet contextText = '';\nlet articlesCited = [];\nlet topScore = 0;\n\nfor (let i = 0; i < matchList.length; i++) {\n  const meta = matchList[i].metadata || {};\n  const score = matchList[i].score || 0;\n  const text = (meta.text || '').replace(/\\\\n/g, '\\n');\n  const articleLabel = meta.article_label || '';\n  \n  contextText += articleLabel + '\\n' + text + '\\n\\n';\n  \n  // Track cited articles and top confidence score\n  if (articleLabel && !articlesCited.includes(articleLabel)) {\n    articlesCited.push(articleLabel);\n  }\n  if (score > topScore) topScore = score;\n}\n\nconst sessionData = $('Session Manager').first().json;\n\nreturn [{\n  json: {\n    chatInput: sessionData.chatInput,\n    context: contextText,\n    session_id: sessionData.session_id,\n    user_id: sessionData.user_id,\n    request_time: sessionData.request_time,\n    // RAG metadata passed forward\n    articles_retrieved: articlesCited,\n    top_confidence: topScore,\n    retrieval_count: matchList.length\n  }\n}];\n"
      },
